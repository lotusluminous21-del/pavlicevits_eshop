                'Authorization': `Basic ${Buffer.from(this.secretKey + ':').toString('base64')}`
            },
            body: JSON.stringify(payload)
        });

        if (!response.ok) {
            // Handle error safely
            return { success: false, refundId: '' };
        }

        const data = await response.json();
        return {
            success: true,
            refundId: data.token || 'unknown_refund_id'
        };
    }
