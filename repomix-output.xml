                <FirestoreProvider sdk={firestore}>
                    <FunctionsProvider sdk={functions}>
                        {children}
                    </FunctionsProvider>
                </FirestoreProvider>
            </AuthProvider>
        </FirebaseAppProvider>
    );
}
