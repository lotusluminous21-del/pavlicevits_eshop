    qr = qrcode.QRCode(
        version=1,
        error_correction=qrcode.constants.ERROR_CORRECT_L,
        box_size=10,
        border=4,
    )
    qr.add_data(qr_data)
    qr.make(fit=True)
    
    factory = qrcode.image.svg.SvgImage
    img = qr.make_image(fill_color="black", back_color="white", image_factory=factory)
    
    buffer = BytesIO()
    img.save(buffer)
    return buffer.getvalue().decode()
